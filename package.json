{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "bun@1.3.13",
	"engines": {
		"bun": ">=1.3.13"
	},
	"scripts": {
		"claude:pipeline": "node .claude/scripts/pipeline.cjs",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/generated/paraglide --strategy url cookie baseLocale --is-server \"import.meta.env.SSR\"",
		"prepare": "paraglide-js compile --project ./project.inlang --outdir ./src/generated/paraglide --strategy url cookie baseLocale --is-server \"import.meta.env.SSR\" && svelte-kit sync || echo ''",
		"check": "paraglide-js compile --project ./project.inlang --outdir ./src/generated/paraglide --strategy url cookie baseLocale --is-server \"import.meta.env.SSR\" && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "paraglide-js compile --project ./project.inlang --outdir ./src/generated/paraglide --strategy url cookie baseLocale --is-server \"import.meta.env.SSR\" && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.1",
		"@tanstack/svelte-query": "^6.1.27",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"shadcn-svelte": "^1.2.7",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@iconify-json/lucide": "^1.2.105",
		"@inlang/paraglide-js": "^2.15.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^22",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"unplugin-icons": "^23.0.1",
		"vite": "^8.0.7"
	}
}
